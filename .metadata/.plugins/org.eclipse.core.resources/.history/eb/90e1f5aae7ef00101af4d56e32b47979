    private String executeCode(String language, String code)
            throws IOException, InterruptedException {

        Map<String, String> images = new HashMap<>();
        images.put("java", "eclipse-temurin:17-jdk");

        images.put("python", "python:3.9-slim");
        images.put("javascript", "node:18-alpine");

        File tempDir = Files.createTempDirectory("code").toFile();
        String filename = getFilename(language);
        File codeFile = new File(tempDir, filename);
        Files.write(codeFile.toPath(), code.getBytes());

        String[] cmd = {
            "docker", "run", "--privileged",
            "-v", tempDir.getAbsolutePath() + ":/app",
            "-v", "/var/run/docker.sock:/var/run/docker.sock",
            "--privileged",
            "--memory", "256m",
            "--network", "none",
            images.get(language),
            "sh", "-c", getExecutionCommand(language, filename)
        };

        Process process = new ProcessBuilder(cmd).start();

        boolean finished = process.waitFor(200, TimeUnit.SECONDS);
        if (!finished) {
            process.destroyForcibly();
            return " Execution timed out";
        }

        StringBuilder output = new StringBuilder();
        String line;

        
        BufferedReader stdout = new BufferedReader(
                new InputStreamReader(process.getInputStream()));
        while ((line = stdout.readLine()) != null) {
            output.append(line).append("\n");
        }

   
        BufferedReader stderr = new BufferedReader(
                new InputStreamReader(process.getErrorStream()));
        while ((line = stderr.readLine()) != null) {
            output.append("ERROR: ").append(line).append("\n");
        }

        int exitCode = process.exitValue();
        

        if (output.length() == 0) {
            return exitCode == 0
                    ? "Program finished with no output."
                    : "Program failed with exit code " + exitCode;
        }

        return output.toString();
    }

    
    private String getExecutionCommand(String language, String filename) {
        switch (language) {
            case "java":
                return "cd /app && javac " + filename + 
                       " && java " + filename.replace(".java", "");
            case "python":
                return "python /app/" + filename;
            case "javascript":
                return "node /app/" + filename;
            default:
                return "echo 'Unsupported language'";
        }
    }
    private String getFilename(String language) {
        if ("java".equals(language)) {
            return "Main.java";
        } else if ("python".equals(language)) {
            return "main.py";
        } else if ("javascript".equals(language)) {
            return "script.js";
        } else if ("c".equals(language)) {
            return "program.c";
        } else if ("cpp".equals(language)) {
            return "program.cpp";
        }
        return "code.txt";
    }
    private void sanitize(String code) throws Exception {
    	final String[] FORBIDDEN = {
    		    
    		    "subprocess"
    		};

        String lower = code.toLowerCase();

        for (String keyword : FORBIDDEN) {
            if (lower.contains(keyword)) {
                throw new Exception(
                    "Use of forbidden keyword detected: " + keyword
                );
            }
        }
    }

}