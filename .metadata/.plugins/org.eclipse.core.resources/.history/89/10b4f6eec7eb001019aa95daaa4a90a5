		dispatch.forward(request, response);
	}
    
    protected void doPost(HttpServletRequest req, HttpServletResponse resp) 
            throws ServletException, IOException {
        
        //resp.setContentType("text/plain");
        //PrintWriter out = resp.getWriter();
    	System.out.println("=== TEST SERVLET CALLED ===");
        System.out.println("Time: " + new java.util.Date());
        String language = req.getParameter("language");
        
        String code = req.getParameter("code");
        
        try {
            String output = executeCode(language, code);
            req.setAttribute("output", output);
            //resp.getWriter().append(output);
            System.out.println(output);
        } catch (Exception e) {
            //out.println("Error:onw " + e.getMessage());
        	req.setAttribute("output", "not compiling");
            //resp.sendError(400, e.getMessage());
            //resp.getWriter().append("idk the bug: ").append(req.getContextPath());
    		
        }
        //req.setAttribute("output", output);
        req.setAttribute("code", code);
        req.setAttribute("language", language);

        RequestDispatcher rd = req.getRequestDispatcher("online.jsp");
        rd.forward(req, resp);
    }
    
    private String executeCode(String language, String code) 
            throws IOException, InterruptedException,Exception {
        
        // Map to official Docker images (NO DOCKERFILE NEEDED!)
        Map<String, String> images = new HashMap<>();
        images.put("java", "openjdk:17-slim");
        images.put("python", "python:3.9-slim");
        images.put("javascript", "node:18-alpine");
        
        // Create temp file
        File tempDir = Files.createTempDirectory("code").toFile();
        String filename = getFilename(language);
        File codeFile = new File(tempDir, filename);
        Files.write(codeFile.toPath(), code.getBytes());
        
        // Build docker command
        String[] cmd = {
            "docker", "run", "--rm",
            "-v", tempDir.getAbsolutePath() + ":/app:ro",
            "--memory", "256m",
            "--network", "none",
            images.get(language),
            "sh", "-c", getExecutionCommand(language, filename)
        };
        
        
        // Execute
        Process process = new ProcessBuilder(cmd).start();
        boolean finished = process.waitFor(80, TimeUnit.SECONDS);
        if (!finished) {
            process.destroyForcibly();
            //throw new Exception("timeout");
            return "⏱ Execution timed out";
            
        }
        
        // Read output
        BufferedReader reader = new BufferedReader(
            new InputStreamReader(process.getInputStream()));
        StringBuilder output = new StringBuilder();
        String line;
        while ((line = reader.readLine()) != null) {
            output.append(line).append("\n");
        }
        System.out.println(output);
        
        // Cleanup
        //deleteDirectory(tempDir);
        
        return output.toString();
    }
    
    private String getExecutionCommand(String language, String filename) {
        switch (language) {
            case "java":
                return "cd /app && javac " + filename + 
                       " && java " + filename.replace(".java", "");
            case "python":
                return "python /app/" + filename;
            case "javascript":
                return "node /app/" + filename;
            default:
                return "echo 'Unsupported language'";
        }
    }
    private String getFilename(String language) {
        if ("java".equals(language)) {
            return "Main.java";
        } else if ("python".equals(language)) {
            return "main.py";
        } else if ("javascript".equals(language)) {
            return "script.js";
        } else if ("c".equals(language)) {
            return "program.c";
        } else if ("cpp".equals(language)) {
            return "program.cpp";
        }
        return "code.txt";
    }
}